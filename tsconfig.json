{
  "compilerOptions": {
    /* 1. Project Layout */
    "rootDir": "./",
    "outDir": "./dist",

    /* 2. Language & Environment */
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "lib": ["ESNext"],
    "types": ["node"],

    /* 3. Mixed Project Support */
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* 4. Speed & Compatibility */
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "skipLibCheck": true,

    /* 5. Outputs for Debugging */
    "sourceMap": true,
    "declaration": false,
    "declarationMap": false,

    /* 6. Strictness Balance */
    "strict": true,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["**/*.ts", "**/*.js"],
  "exclude": ["node_modules", "dist"]
}
