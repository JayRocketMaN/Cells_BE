{
  "compilerOptions": {
    /*Project Layout */
    "rootDir": "./",
    "outDir": "./dist",

    /*Language & Environment */
    "target": "ESNext",
    "module": "NodeNext",               // Required for modern Node.js ESM execution
    "moduleResolution": "NodeNext",     // Correctly evaluates relative extensions like .js

    "lib": ["ESNext"],
    "types": ["node"],

    /*Mixed Project Support */
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,

    /*Speed & Compatibility */
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "skipLibCheck": true,               // Keeps CI builds extremely fast

    /*Outputs for Debugging */
    "sourceMap": true,
    "declaration": false,
    "declarationMap": false,

    /*Strictness Balance */
    "strict": true,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["**/*.ts", "**/*.js"],
  "exclude": ["node_modules", "dist"]
}
